<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Alttuldugi" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/brand_primary_dark</item>
        <item name="android:windowBackground">@color/surface_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceContainer">@color/surface_card_alt</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/divider_dark</item>
    </style>

    <style name="ShapeAppearance.Alttuldugi.Input" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="Widget.Alttuldugi.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">filled</item>
        <item name="boxBackgroundColor">@color/input_fill_bg</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="hintTextColor">@color/input_hint</item>
        <item name="android:textColorHint">@color/input_hint</item>
        <item name="errorTextColor">@color/accent_warning</item>
        <item name="endIconTint">@color/text_secondary</item>
    </style>
</resources>
